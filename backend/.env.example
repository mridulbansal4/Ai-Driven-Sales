# LiveKit (local dev server — match your livekit.yaml / token server)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Ollama (LLM — Qwen)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen-sales
OLLAMA_TEMPERATURE=0.6
OLLAMA_MAX_TOKENS=120

# Whisper (STT)
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=int8
# Language: 'auto' = detect per utterance (default). Force with 'hi' or 'en'.
WHISPER_LANGUAGE=auto

# Kokoro (TTS) — voice per language; English is auto-picked, Hindi used when the
# reply is in Devanagari. See hexgrad/Kokoro-82M for available voices.
# KOKORO_VOICE_EN=af_heart
# KOKORO_VOICE_HI=hf_alpha

# Optional: only if Whisper fails without legacy Purfview DLLs
# WHISPER_LEGACY_DLLS=0

# Optional: console audio devices (substring match)
# INPUT_DEVICE=Realtek
# OUTPUT_DEVICE=Realtek

LOG_LEVEL=INFO
